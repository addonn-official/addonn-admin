@@ -0,0 +1,31 @@
+import React from 'react';
+import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
+import { Input } from '@/components/ui/input';
+
+interface SubHeadingDialogProps {
+  isOpen: boolean;
+  onOpenChange: (open: boolean) => void;
+  selectedSubTopic: any;
+  updateSubTopicName: (topicId: number, subId: number, name: string) => void;
+}
+
+export default function SubHeadingDialog({
+  isOpen,
+  onOpenChange,
+  selectedSubTopic,
+  updateSubTopicName,
+}: SubHeadingDialogProps) {
+  return (
+    <Dialog open={isOpen} onOpenChange={onOpenChange}>
+      <DialogContent>
+        <DialogHeader>
+          <DialogTitle>Edit Subtopic</DialogTitle>
+        </DialogHeader>
+        {selectedSubTopic && (
+          <Input
+            value={selectedSubTopic.name}
+            onChange={(e) =>
+              updateSubTopicName(selectedSubTopic.parent.id, selectedSubTopic.id, e.target.value)
+            }
+          />
+        )}
+      </DialogContent>
+    </Dialog>
+  );
+}
